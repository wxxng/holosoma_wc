<mujoco model="open_box">
  <compiler angle="degree"/>
  <option gravity="0 0 -9.81"/>

  <worldbody>
    <!-- Ground -->
    <geom name="ground" type="plane" size="2 2 0.1" pos="0 0 0" rgba="0.9 0.9 0.9 1"/>

    <!-- Open-top box (0.5 x 0.5 x 0.2 m) -->
    <body name="box" pos="0 0 0">

      <!-- Bottom -->
      <geom name="bottom"
            type="box"
            pos="0 0 0.01"
            size="0.25 0.25 0.01"
            rgba="0.6 0.6 0.6 1"/>

      <!-- +X wall -->
      <geom name="wall_px"
            type="box"
            pos="0.24 0 0.11"
            size="0.01 0.25 0.10"
            rgba="0.3 0.3 0.8 1"/>

      <!-- -X wall -->
      <geom name="wall_nx"
            type="box"
            pos="-0.24 0 0.11"
            size="0.01 0.25 0.10"
            rgba="0.3 0.3 0.8 1"/>

      <!-- +Y wall -->
      <geom name="wall_py"
            type="box"
            pos="0 0.24 0.11"
            size="0.23 0.01 0.10"
            rgba="0.3 0.3 0.8 1"/>

      <!-- -Y wall -->
      <geom name="wall_ny"
            type="box"
            pos="0 -0.24 0.11"
            size="0.23 0.01 0.10"
            rgba="0.3 0.3 0.8 1"/>

    </body>
  </worldbody>
</mujoco>