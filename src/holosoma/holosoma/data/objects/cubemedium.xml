<mujoco model="cubemedium">
  <compiler angle="radian" meshdir="."/>

  <asset>
    <mesh name="cubemedium_mesh" file="cubemedium.obj"/>
  </asset>

  <worldbody>
    <!-- Dynamic object for WBT (name must match WBT object_name) -->
    <body name="object" pos="0 0 0.6">
      <freejoint/>
      <!-- Collision: simple box for stability -->
      <geom name="object_col"
            type="box"
            size="0.04 0.04 0.04"
            density="500"
            contype="3"
            conaffinity="3"
            friction="0.9 0.5 0.5"/>
      <!-- Visual mesh -->
      <geom name="object_vis"
            type="mesh"
            mesh="cubemedium_mesh"
            contype="0"
            conaffinity="0"
            rgba="0.7 0.8 0.9 1"/>
    </body>
  </worldbody>
</mujoco>
